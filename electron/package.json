{
  "name": "remote-electron",
  "version": "1.0.1",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist-mac": "rimraf dist && electron-builder --mac --dir=outMac",
    "dist-win": "rimraf dist && electron-builder --win --x64"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "rimraf": "^5.0.5"
  },
  "build": {
    "productName": "远程",
    "appId": "remote",
    "asar": false,
    "compression": "store",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!outMac"
    ],
    "dmg": {
      "icon": "img/512x512px.png",
      "iconSize": 100,
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://resource.doudoubot.cn/download/assistant/mac"
      }
    ],
    "mac": {
      "icon": "img/512x512px.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "img/512x512px.png",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true
    }
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.13",
    "electron-log": "4.4.7",
    "socket.io-client": "^4.7.4"
  }
}
